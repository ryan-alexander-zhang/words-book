# PostgreSQL connection string used by Prisma and Next.js API routes
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/words_book"

# Required by Auth.js in production and recommended locally
AUTH_SECRET="replace-with-a-long-random-string"

# Recommended for self-hosted production so Auth.js can resolve the canonical origin safely
# AUTH_URL="https://your-domain"
#
# Only set this if your reverse proxy preserves the Host header safely
# AUTH_TRUST_HOST="true"

# Google OAuth credentials for Auth.js
AUTH_GOOGLE_ID="replace-with-google-client-id"
AUTH_GOOGLE_SECRET="replace-with-google-client-secret"
